generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// File model to store file details
model File {
    id                String             @id @default(uuid())
    fileName          String
    path              String
    mimeType          String
    size              Int
    fileType          FileType
    createdAt         DateTime           @default(now())
    updatedAt         DateTime           @updatedAt
    productGroupFiles ProductGroupFile[] // Updated to link with ProductGroup
}

// Enum for file types
enum FileType {
    IMAGE
    DOCUMENT
    OTHER
}

// ProductGroup model (e.g., "A1", "A2", "A3")
model ProductGroup {
    id                String             @id @default(uuid())
    name              String // e.g., "A1", "A2", "A3"
    createdAt         DateTime           @default(now())
    updatedAt         DateTime           @updatedAt
    products          Product[]
    Invoice           Invoice[]
    productGroupFiles ProductGroupFile[] // Added to link with File
}

// Product model (individual products within a group)
model Product {
    id             String           @id @default(uuid())
    name           String
    allTotalCount  Int
    createdAt      DateTime         @default(now())
    updatedAt      DateTime         @updatedAt
    productGroupId String?
    productGroup   ProductGroup?    @relation(fields: [productGroupId], references: [id])
    productSetting productSetting[]
}

// ProductSetting model to store settings for each product
model productSetting {
    id         String      @id @default(uuid())
    totalCount Int
    createdAt  DateTime    @default(now())
    updatedAt  DateTime    @updatedAt
    productId  String
    product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
    sizeGroups SizeGroup[] // Removed files field
}

// Junction table for many-to-many relationship between ProductGroup and File
model ProductGroupFile {
    id             String       @id @default(uuid())
    productGroupId String
    fileId         String
    productGroup   ProductGroup @relation(fields: [productGroupId], references: [id], onDelete: Cascade)
    file           File         @relation(fields: [fileId], references: [id])
}

// SizeGroup model to group sizes and their quantities
model SizeGroup {
    id               String             @id @default(uuid())
    size             String
    quantity         Int
    createdAt        DateTime           @default(now())
    updatedAt        DateTime           @updatedAt
    productSettingId String
    productSetting   productSetting     @relation(fields: [productSettingId], references: [id], onDelete: Cascade)
    colorSizes       ProductColorSize[]
}

// ProductColorSize model to store color and size combinations
model ProductColorSize {
    id          String    @id @default(uuid())
    quantity    Int
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    sizeGroupId String
    colorId     String
    sizeId      String
    sizeGroup   SizeGroup @relation(fields: [sizeGroupId], references: [id], onDelete: Cascade)
    color       Color     @relation(fields: [colorId], references: [id])
    size        Size      @relation(fields: [sizeId], references: [id])
}

// Color model
model Color {
    id               String             @id @default(uuid())
    name             String             @unique
    createdAt        DateTime           @default(now())
    updatedAt        DateTime           @updatedAt
    ProductColorSize ProductColorSize[]
}

// Size model
model Size {
    id               String             @id @default(uuid())
    name             String             @unique
    createdAt        DateTime           @default(now())
    updatedAt        DateTime           @updatedAt
    ProductColorSize ProductColorSize[]
}

// Invoice model
model Invoice {
    id             String            @id @default(uuid())
    number         Int
    perentId       String
    protsessIsOver Boolean           @default(false)
    departmentId   String
    department     String
    productGroupId String
    ProductGroup   ProductGroup      @relation(fields: [productGroupId], references: [id])
    totalCount     Int
    status         ProductProtsess[]
    createdAt      DateTime          @default(now())
    updatedAt      DateTime          @updatedAt
}

// Department model
model Department {
    id              String            @id @default(uuid())
    name            String            @unique
    createdAt       DateTime          @default(now())
    updatedAt       DateTime          @updatedAt
    Employee        Employee[]
    ProductProtsess ProductProtsess[]
}

// Employee model
model User {
    id        String    @id @default(uuid())
    login     String    @unique
    password  String
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    role      userRole
    employee  Employee? @relation
}

model Employee {
    id           String     @id @default(uuid())
    name         String
    userId       String     @unique
    departmentId String
    createdAt    DateTime   @default(now())
    updatedAt    DateTime   @updatedAt
    department   Department @relation(fields: [departmentId], references: [id])
    user         User       @relation(fields: [userId], references: [id])
}

// ProductProtsess model
model ProductProtsess {
    createdAt            DateTime   @default(now())
    updatedAt            DateTime   @updatedAt
    id                   String     @id @default(uuid())
    date                 DateTime   @default(now())
    protsessIsOver       Boolean    @default(false)
    status               String
    employeeId           String
    departmentName       String
    targetDepartment     String?
    acceptanceDepartment String?
    departmentId         String
    acceptCount          Int
    sendedCount          Int
    invalidCount         Int
    residueCount         Int
    invalidReason        String
    department           Department @relation(fields: [departmentId], references: [id])
    invoiceId            String
    Invoice              Invoice    @relation(fields: [invoiceId], references: [id])
}

// Enum for user roles
enum userRole {
    ADMIN
    USER
}
