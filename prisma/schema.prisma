generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// Enum for file types
enum FileType {
    IMAGE
    DOCUMENT
    OTHER
}

// Enum for process status
enum ProductProtsessStatus {
    Pending
    Yuborilgan
    ToliqYuborilmagan
    QabulQilingan
}

// Enum for user roles
enum userRole {
    ADMIN
    USER
}

// File model to store file details
model File {
    id                String             @id @default(uuid())
    fileName          String
    path              String
    mimeType          String
    size              Int
    fileType          FileType
    createdAt         DateTime           @default(now())
    updatedAt         DateTime           @updatedAt
    productGroupFiles ProductGroupFile[]
}

// ProductGroup model (e.g., "A1", "A2", "A3")
model ProductGroup {
    id                String                @id @default(uuid())
    name              String
    createdAt         DateTime              @default(now())
    updatedAt         DateTime              @updatedAt
    products          Product[]
    invoices          Invoice[]
    productGroupFiles ProductGroupFile[]
    isSended          Boolean               @default(false)
    status            ProductProtsessStatus
}

// Product model (individual products within a group)
model Product {
    id             String                @id @default(uuid())
    name           String
    allTotalCount  Int
    createdAt      DateTime              @default(now())
    updatedAt      DateTime              @updatedAt
    productGroupId String?
    productGroup   ProductGroup?         @relation(fields: [productGroupId], references: [id])
    productSetting productSetting[]
    processes      ProductProcess[]
    isSended       Boolean               @default(false)
    status         ProductProtsessStatus
}

// ProductSetting model to store settings for each product
model productSetting {
    id         String                @id @default(uuid())
    totalCount Int
    createdAt  DateTime              @default(now())
    updatedAt  DateTime              @updatedAt
    productId  String
    product    Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
    sizeGroups SizeGroup[] // Relation to SizeGroup
    isSended   Boolean               @default(false)
    status     ProductProtsessStatus
}

// SizeGroup model to group color-size combinations
model SizeGroup {
    id               String                @id @default(uuid())
    size             String
    quantity         Int
    status           ProductProtsessStatus
    createdAt        DateTime              @default(now())
    updatedAt        DateTime              @updatedAt
    productSettingId String
    productSetting   productSetting        @relation(fields: [productSettingId], references: [id], onDelete: Cascade)
    colorSizes       ProductColorSize[]
}

// Junction table for many-to-many relationship between ProductGroup and File
model ProductGroupFile {
    id             String                @id @default(uuid())
    productGroupId String
    fileId         String
    productGroup   ProductGroup          @relation(fields: [productGroupId], references: [id], onDelete: Cascade)
    file           File                  @relation(fields: [fileId], references: [id])
    isSended       Boolean               @default(false)
    status         ProductProtsessStatus
}

// ProductColorSize model to store color and size combinations
model ProductColorSize {
    id          String                @id @default(uuid())
    quantity    Int
    createdAt   DateTime              @default(now())
    updatedAt   DateTime              @updatedAt
    sizeGroupId String
    colorId     String
    sizeId      String
    sizeGroup   SizeGroup             @relation(fields: [sizeGroupId], references: [id], onDelete: Cascade)
    color       Color                 @relation(fields: [colorId], references: [id])
    size        Size                  @relation(fields: [sizeId], references: [id])
    processes   ColorSizeProcess[]
    isSended    Boolean               @default(false)
    status      ProductProtsessStatus
}

// Color model
model Color {
    id         String                @id @default(uuid())
    name       String                @unique
    createdAt  DateTime              @default(now())
    updatedAt  DateTime              @updatedAt
    colorSizes ProductColorSize[]
    isSended   Boolean               @default(false)
    status     ProductProtsessStatus @default(Pending) // Add default value
}

// Size model
model Size {
    id         String                @id @default(uuid())
    name       String                @unique
    createdAt  DateTime              @default(now())
    updatedAt  DateTime              @updatedAt
    colorSizes ProductColorSize[]
    isSended   Boolean               @default(false)
    status     ProductProtsessStatus @default(Pending) // Add default value
}

// OutsourseCompany model
model OutsourseCompany {
    id        String    @id @default(uuid())
    name      String    @unique
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    invoices  Invoice[]
}

// Invoice model
model Invoice {
    id                 String            @id @default(uuid())
    number             Int
    perentId           String
    protsessIsOver     Boolean           @default(false)
    departmentId       String
    department         String
    productGroupId     String
    productGroup       ProductGroup      @relation(fields: [productGroupId], references: [id])
    totalCount         Int
    status             ProductProtsess[]
    createdAt          DateTime          @default(now())
    updatedAt          DateTime          @updatedAt
    isOutsource        Boolean           @default(false)
    outsourseCompany   OutsourseCompany? @relation(fields: [outsourseCompanyId], references: [id])
    outsourseCompanyId String?
    ProductProcess     ProductProcess[]
}

// Department model
model Department {
    id        String            @id @default(uuid())
    name      String            @unique
    createdAt DateTime          @default(now())
    updatedAt DateTime          @updatedAt
    employees Employee[]
    processes ProductProtsess[]
}

// User model
model User {
    id        String    @id @default(uuid())
    login     String    @unique
    password  String
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    role      userRole
    employee  Employee?
}

// Employee model
model Employee {
    id           String     @id @default(uuid())
    name         String
    userId       String     @unique
    departmentId String
    createdAt    DateTime   @default(now())
    updatedAt    DateTime   @updatedAt
    department   Department @relation(fields: [departmentId], references: [id])
    user         User       @relation(fields: [userId], references: [id])
}

// ProductProtsess model for invoice-level process tracking
model ProductProtsess {
    id                   String     @id @default(uuid())
    createdAt            DateTime   @default(now())
    updatedAt            DateTime   @updatedAt
    date                 DateTime   @default(now())
    protsessIsOver       Boolean    @default(false)
    status               String
    employeeId           String
    departmentName       String
    targetDepartment     String?
    acceptanceDepartment String?
    departmentId         String
    acceptCount          Int
    sendedCount          Int
    invalidCount         Int
    residueCount         Int
    invalidReason        String
    department           Department @relation(fields: [departmentId], references: [id])
    invoiceId            String
    invoice              Invoice    @relation(fields: [invoiceId], references: [id])
}

// Process tracking for Product
model ProductProcess {
    id                 String             @id @default(uuid())
    createdAt          DateTime           @default(now())
    updatedAt          DateTime           @updatedAt
    protsessIsOver     Boolean            @default(false)
    status             String
    employeeId         String
    departmentName     String
    departmentId       String
    acceptCount        Int
    sendedCount        Int
    invalidCount       Int
    invalidReason      String
    residueCount       Int
    productId          String
    product            Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
    invoiceId          String
    invoice            Invoice            @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
    colorSizeProcesses ColorSizeProcess[]
}

// Process tracking for ProductColorSize
model ColorSizeProcess {
    id               String           @id @default(uuid())
    createdAt        DateTime         @default(now())
    updatedAt        DateTime         @updatedAt
    protsessIsOver   Boolean          @default(false)
    status           String
    employeeId       String
    departmentName   String
    departmentId     String
    acceptCount      Int
    sendedCount      Int
    invalidCount     Int
    invalidReason    String
    residueCount     Int
    colorSizeId      String
    colorSize        ProductColorSize @relation(fields: [colorSizeId], references: [id], onDelete: Cascade)
    productProcessId String
    productProcess   ProductProcess   @relation(fields: [productProcessId], references: [id], onDelete: Cascade)
}
