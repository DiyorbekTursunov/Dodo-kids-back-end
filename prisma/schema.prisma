generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Color {
    id        String    @id @default(uuid())
    name      String    @unique
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    Product   Product[] @relation("ColorToProduct")
}

model Size {
    id        String    @id @default(uuid())
    name      String    @unique
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    Product   Product[] @relation("ProductToSize")
}

model Department {
    id              String            @id @default(uuid())
    name            String            @unique
    createdAt       DateTime          @default(now())
    updatedAt       DateTime          @updatedAt
    Employee        Employee[]
    ProductProtsess ProductProtsess[]
}

model Employee {
    id           String     @id @default(uuid())
    name         String
    userId       String
    departmentId String
    createdAt    DateTime   @default(now())
    updatedAt    DateTime   @updatedAt
    department   Department @relation(fields: [departmentId], references: [id])
    user         User       @relation(fields: [userId], references: [id])
}

model User {
    id        String     @id @default(uuid())
    login     String     @unique
    password  String
    createdAt DateTime   @default(now())
    updatedAt DateTime   @updatedAt
    role      userRole
    Employee  Employee[]
}

model ProductPack {
    id             String            @id @default(uuid())
    name           String?
    perentId       String
    protsessIsOver Boolean           @default(false)
    departmentId   String
    department     String
    createdAt      DateTime          @default(now())
    updatedAt      DateTime          @updatedAt
    productId      String
    totalCount     Int
    Product        Product           @relation(fields: [productId], references: [id])
    status         ProductProtsess[]
}

model Product {
    createdAt   DateTime      @default(now()) // Added timestamp
    updatedAt   DateTime      @updatedAt // Added timestamp
    id          String        @id @default(uuid())
    model       String
    ProductPack ProductPack[]
    color       Color[]       @relation("ColorToProduct")
    size        Size[]        @relation("ProductToSize")
}

model ProductProtsess {
    createdAt        DateTime    @default(now()) // Added timestamp
    updatedAt        DateTime    @updatedAt // Added timestamp
    id               String      @id @default(uuid())
    date             DateTime    @default(now())
    protsessIsOver   Boolean     @default(false)
    status           String
    employeeId       String

    departmentName   String
    targetDepartment String?

    departmentId     String
    productpackId    String
    acceptCount      Int
    sendedCount      Int
    invalidCount     Int
    residueCount     Int
    invalidReason    String
    department       Department  @relation(fields: [departmentId], references: [id])
    productPack      ProductPack @relation(fields: [productpackId], references: [id])

    fromWhere        String?     @default("")
}

enum userRole {
    ADMIN
    USER
}
