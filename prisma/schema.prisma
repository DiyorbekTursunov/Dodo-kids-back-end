generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Color {
    id               String             @id @default(uuid())
    name             String             @unique
    createdAt        DateTime           @default(now())
    updatedAt        DateTime           @updatedAt
    ProductColorSize ProductColorSize[]
}

model Size {
    id               String             @id @default(uuid())
    name             String             @unique
    createdAt        DateTime           @default(now())
    updatedAt        DateTime           @updatedAt
    ProductColorSize ProductColorSize[]
}

model File {
    id        String   @id @default(uuid())
    fileName  String
    path      String
    mimeType  String
    size      Int
    fileType  FileType
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

enum FileType {
    IMAGE
    DOCUMENT
    OTHER
}

model Department {
    id              String            @id @default(uuid())
    name            String            @unique
    createdAt       DateTime          @default(now())
    updatedAt       DateTime          @updatedAt
    Employee        Employee[]
    ProductProtsess ProductProtsess[]
}

model Employee {
    id           String     @id @default(uuid())
    name         String
    userId       String
    departmentId String
    createdAt    DateTime   @default(now())
    updatedAt    DateTime   @updatedAt
    department   Department @relation(fields: [departmentId], references: [id])
    user         User       @relation(fields: [userId], references: [id])
}

model User {
    id        String     @id @default(uuid())
    login     String     @unique
    password  String
    createdAt DateTime   @default(now())
    updatedAt DateTime   @updatedAt
    role      userRole
    Employee  Employee[]
}

model Invoice {
    id     String @id @default(uuid())
    number Int

    perentId       String
    protsessIsOver Boolean           @default(false)
    departmentId   String
    department     String
    productId      String
    totalCount     Int
    Product        Product           @relation(fields: [productId], references: [id])
    status         ProductProtsess[]

    ProductPacks ProductPack[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model ProductPack {
    id String @id @default(uuid())

    InvoiceId String
    Invoice   Invoice @relation(fields: [InvoiceId], references: [id])

    productSettings productSetting[]

    Product Product? @relation(fields: [productId], references: [id])

    productId String?
}

model Product {
    id             String           @id @default(uuid())
    name           String
    createdAt      DateTime         @default(now())
    updatedAt      DateTime         @updatedAt
    ProductPack    ProductPack[]
    Invoice        Invoice[]
    productSetting productSetting[]
}

model productSetting {
    id String @id @default(uuid())

    productPackId String
    productPack   ProductPack @relation(fields: [productPackId], references: [id])

    totalCount Int
    createdAt  DateTime    @default(now())
    updatedAt  DateTime    @updatedAt
    productId  String
    product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
    sizeGroups SizeGroup[]
}

model SizeGroup {
    id        String   @id @default(uuid())
    size      String
    quantity  Int
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    productSettingId String
    productSetting   productSetting @relation(fields: [productSettingId], references: [id], onDelete: Cascade)

    colorSizes ProductColorSize[]
}

model ProductColorSize {
    id          String    @id @default(uuid())
    quantity    Int
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    sizeGroupId String
    colorId     String
    sizeId      String
    sizeGroup   SizeGroup @relation(fields: [sizeGroupId], references: [id], onDelete: Cascade)
    color       Color     @relation(fields: [colorId], references: [id])
    size        Size      @relation(fields: [sizeId], references: [id])
}

model ProductProtsess {
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt
    id             String   @id @default(uuid())
    date           DateTime @default(now())
    protsessIsOver Boolean  @default(false)
    status         String
    employeeId     String

    departmentName       String
    targetDepartment     String?
    acceptanceDepartment String?

    departmentId String

    acceptCount   Int
    sendedCount   Int
    invalidCount  Int
    residueCount  Int
    invalidReason String
    department    Department @relation(fields: [departmentId], references: [id])

    invoiceId String
    Invoice   Invoice @relation(fields: [invoiceId], references: [id])
}

enum userRole {
    ADMIN
    USER
}
