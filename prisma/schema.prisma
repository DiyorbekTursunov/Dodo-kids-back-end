// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Employee model
model Employee {
  id        Int       @id @default(autoincrement())
  login     String    @unique
  password  String
  type      EmployeeType
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// Admin model
model Admin {
  id        Int       @id @default(autoincrement())
  login     String    @unique
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// Employee types enum
enum EmployeeType {
  ombor
  bichuv
  tikuv
  skaner
  qadoqlash
}
