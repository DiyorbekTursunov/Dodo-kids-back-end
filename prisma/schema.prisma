generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Color {
    id               String             @id @default(uuid())
    name             String             @unique
    createdAt        DateTime           @default(now())
    updatedAt        DateTime           @updatedAt
    ProductColorSize ProductColorSize[]
}

model Size {
    id               String             @id @default(uuid())
    name             String             @unique
    createdAt        DateTime           @default(now())
    updatedAt        DateTime           @updatedAt
    ProductColorSize ProductColorSize[]
}

model Department {
    id              String            @id @default(uuid())
    name            String            @unique
    createdAt       DateTime          @default(now())
    updatedAt       DateTime          @updatedAt
    Employee        Employee[]
    ProductProtsess ProductProtsess[]
}

model Employee {
    id           String     @id @default(uuid())
    name         String
    userId       String
    departmentId String
    createdAt    DateTime   @default(now())
    updatedAt    DateTime   @updatedAt
    department   Department @relation(fields: [departmentId], references: [id])
    user         User       @relation(fields: [userId], references: [id])
}

model User {
    id        String     @id @default(uuid())
    login     String     @unique
    password  String
    createdAt DateTime   @default(now())
    updatedAt DateTime   @updatedAt
    role      userRole
    Employee  Employee[]
}

model ProductPack {
    id             String            @id @default(uuid())
    name           String?
    perentId       String
    protsessIsOver Boolean           @default(false)
    departmentId   String
    department     String
    createdAt      DateTime          @default(now())
    updatedAt      DateTime          @updatedAt
    productId      String
    totalCount     Int
    Product        Product           @relation(fields: [productId], references: [id])
    status         ProductProtsess[]
}

model Product {
    id           String        @id @default(uuid())
    createdAt    DateTime      @default(now())
    updatedAt    DateTime      @updatedAt
    ProductPack  ProductPack[]
    productTypes ProductType[]
}

model ProductType {
    id         String      @id @default(uuid())
    name       String
    totalCount Int
    createdAt  DateTime    @default(now())
    updatedAt  DateTime    @updatedAt
    productId  String
    product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
    sizeGroups SizeGroup[]
}

model SizeGroup {
    id            String             @id @default(uuid())
    size          String
    quantity      Int
    createdAt     DateTime           @default(now())
    updatedAt     DateTime           @updatedAt
    productTypeId String
    productType   ProductType        @relation(fields: [productTypeId], references: [id], onDelete: Cascade)
    colorSizes    ProductColorSize[]
}

model ProductColorSize {
    id          String    @id @default(uuid())
    quantity    Int
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    sizeGroupId String
    colorId     String
    sizeId      String
    sizeGroup   SizeGroup @relation(fields: [sizeGroupId], references: [id], onDelete: Cascade)
    color       Color     @relation(fields: [colorId], references: [id])
    size        Size      @relation(fields: [sizeId], references: [id])
}

model ProductProtsess {
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt
    id             String   @id @default(uuid())
    date           DateTime @default(now())
    protsessIsOver Boolean  @default(false)
    status         String
    employeeId     String

    departmentName       String
    targetDepartment     String?
    acceptanceDepartment String?

    departmentId  String
    productpackId String
    acceptCount   Int
    sendedCount   Int
    invalidCount  Int
    residueCount  Int
    invalidReason String
    department    Department  @relation(fields: [departmentId], references: [id])
    productPack   ProductPack @relation(fields: [productpackId], references: [id])
}

enum userRole {
    ADMIN
    USER
}
