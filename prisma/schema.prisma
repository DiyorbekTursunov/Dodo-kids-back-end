generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// Color model for CRUD operations
model Color {
    id        String   @id @default(uuid())
    name      String   @unique
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    materials Line[] // Relation to materials
    Status    Status?  @relation(fields: [statusId], references: [id])
    statusId  String?
}

// Size model for CRUD operations
model Size {
    id        String   @id @default(uuid())
    name      String   @unique
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    Line      Line[] // Relation to materials
    Status    Status?  @relation(fields: [statusId], references: [id])
    statusId  String?
}

// Department/EmployeeType model (represents both employee types and departments)
model Department {
    id        String     @id @default(uuid())
    name      String     @unique
    employees Employee[]
    createdAt DateTime   @default(now())
    updatedAt DateTime   @updatedAt
}

// Employee model
model Employee {
    id           String     @id @default(uuid())
    name         String // Employee name
    login        String     @unique
    password     String
    departmentId String
    department   Department @relation(fields: [departmentId], references: [id])
    createdAt    DateTime   @default(now())
    updatedAt    DateTime   @updatedAt
}

// Admin model
model Admin {
    id        String   @id @default(uuid())
    login     String   @unique
    password  String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model MainProtsess {
    id                   String   @id @default(uuid())
    modelName            String
    protsesIsOver        Boolean  @default(false)
    protsesIsStartedTime DateTime @default(now())
    protsesIsOverTime    String   @default("")

    line           Line[]
    completedLines Line[] @relation("CompletedLines")
}

model Line {
    id             String   @id @default(uuid())
    protsessIsOver Boolean  @default(false)
    departmentId   String
    department     String
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt
    color          Color[]
    size           Size[]

    mainProtsessId String?
    mainProtsess   MainProtsess? @relation(fields: [mainProtsessId], references: [id])

    completedBy MainProtsess[] @relation("CompletedLines")

    umumiySoni Int

    qabulQiluvchiBolim  String
    model               String
    qoshilganlarSoni    Int
    yuborilganlarSoni   Int[]
    qoldiqSolni         Int
    qoshimchaMalumotlar String
    yaroqsizlarSoni     Useless[]

    status Status[]
}

model Status {
    id     String   @id @default(uuid())
    date   DateTime @default(now())
    status String
    userId String
    color  Color[]
    size   Size[]

    product   Line   @relation(fields: [productId], references: [id])
    productId String
}

model Useless {
    id     String @id @default(uuid())
    soni   Int
    sabali String
    lineId String
    line   Line   @relation(fields: [lineId], references: [id])
}
